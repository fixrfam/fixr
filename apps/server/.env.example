# Used for caching frequently used data + publishing async background jobs (Change password on PROD)
REDIS_URL='redis://default:fixr@localhost:6379/0'
# Get this on https://resend.com/api-keys
RESEND_KEY='re_{$}'

# You can put anything as secrets but we recomend generating strong keys at https://tooleroid.com/jwt-secret-generator
JWT_SECRET='' # Used to sign the JWTS
COOKIE_ENCRYPTION_SECRET='' # Used to encrypt cookies

COOKIE_DOMAIN='localhost' # For signing cookies

GOOGLE_AUTH_CLIENT_ID=''
GOOGLE_AUTH_CLIENT_SECRET=''
GOOGLE_AUTH_REDIRECT_URI='http://localhost:3333/auth/google/callback'

# Port for the API to run on
NODE_PORT=3333
FRONTEND_URL='http://localhost:3000'
