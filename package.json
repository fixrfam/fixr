{
  "name": "fixr",
  "private": true,
  "scripts": {
    "dev": "dotenv -- bun run --elide-lines 0 --filter './apps/*' dev",
    "start": "dotenv -- bun run --filter './apps/*' start",
    "build": "bun run --elide-lines 0 build:packages && bun run --elide-lines 0 build:apps",
    "build:packages": "dotenv -- bun run --elide-lines 0 --filter './packages/*' build",
    "build:apps": "dotenv -- bun run --elide-lines 0 --filter './apps/*' build",
    "build:server": "dotenv -- bun run --elide-lines 0 --filter server build",
    "build:workers": "dotenv -- bun run --elide-lines 0 --filter workers build",
    "build:web": "dotenv -- bun run --elide-lines 0 --filter web build",
    "build:admin": "dotenv -- bun run --elide-lines 0 --filter admin build",
    "lint": "dotenv -- bun run --elide-lines 0 --filter '*' lint",
    "lint:write": "dotenv -- bun run --elide-lines 0 --filter '*' lint:write",
    "format": "ultracite fix",
    "db:push": "bun run --elide-lines 0 --filter @fixr/db db:push",
    "db:studio": "bun run --elide-lines 0 --filter @fixr/db db:studio",
    "db:generate": "bun run --elide-lines 0 --filter @fixr/db db:generate",
    "db:migrate": "bun run --elide-lines 0 --filter @fixr/db db:migrate",
    "db:start": "bun run --elide-lines 0 --filter @fixr/db db:start",
    "db:watch": "bun run --elide-lines 0 --filter @fixr/db db:watch",
    "db:stop": "bun run --elide-lines 0 --filter @fixr/db db:stop",
    "db:down": "bun run --elide-lines 0 --filter @fixr/db db:down",
    "deploy": "bun run --elide-lines 0 --filter @fixr/infra deploy",
    "deploy:ci": "bun run --filter @fixr/infra deploy",
    "destroy": "bun run --elide-lines 0 --filter @fixr/infra destroy",
    "destroy:ci": "bun run --filter @fixr/infra destroy",
    "check-types": "bun run --elide-lines 0 --filter '*' check-types",
    "prepare": "husky"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@biomejs/biome": "2.3.11",
      "@fixr/typescript-config": "0.0.0",
      "@react-email/render": "2.0.4",
      "@types/bun": "1.3.6",
      "@types/react": "19.1.2",
      "@types/react-dom": "19.1.3",
      "dotenv": "17.2.4",
      "dotenv-cli": "8.0.0",
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "typescript": "5.5.4",
      "zod": "4.3.6",
      "drizzle-orm": "0.38.3",
      "drizzle-zod": "0.7.0",
      "mysql2": "3.13.0",
      "ioredis": "5.9.2",
      "bullmq": "5.67.3",
      "@react-email/components": "0.0.34",
      "nodemailer": "8.0.1",
      "@opennextjs/cloudflare": "^1.17.1",
      "open-next": "^3.1.3",
      "wrangler": "^4.71.0",
      "vitest": "^4.0.18"
    }
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "@react-email/render": "^2.0.4",
    "dotenv": "^17.2.4",
    "dotenv-cli": "^8.0.0",
    "vitest": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@types/bun": "1.3.6",
    "@types/node": "^25.3.2",
    "admin": "workspace:*",
    "husky": "latest",
    "lint-staged": "latest",
    "prettier": "^3.2.5",
    "typescript": "5.5.4",
    "ultracite": "7.0.12",
    "web": "workspace:*"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.6",
  "resolutions": {
    "drizzle-orm": "0.38.3"
  }
}
