{
  "name": "fixr",
  "private": true,
  "scripts": {
    "dev": "dotenv -- bun run --elide-lines 0 --filter './apps/*' dev",
    "start": "dotenv -- bun run --elide-lines 0 --filter './apps/*' start",
    "build": "bun run --elide-lines 0 build:packages && bun run --elide-lines 0 build:apps",
    "build:packages": "dotenv -- bun run --elide-lines 0 --filter './packages/*' build",
    "build:apps": "dotenv -- bun run --elide-lines 0 --filter './apps/*' build",
    "build:server": "dotenv -- bun run --elide-lines 0 --filter server build",
    "build:web": "dotenv -- bun run --elide-lines 0 --filter web build",
    "build:admin": "dotenv -- bun run --elide-lines 0 --filter admin build",
    "lint": "dotenv -- bun run --elide-lines 0 --filter '*' lint",
    "lint:write": "dotenv -- bun run --elide-lines 0 --filter '*' lint:write",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "migrate": "dotenv -- bun run --elide-lines 0 --filter @fixr/db migrate",
    "generate": "dotenv -- bun run --elide-lines 0 --filter @fixr/db generate",
    "studio": "dotenv -- bun run --elide-lines 0 --filter @fixr/db studio"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.3",
    "prettier": "^3.2.5",
    "typescript": "5.5.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "@react-email/render": "^2.0.4",
    "dotenv": "^17.2.4",
    "dotenv-cli": "^8.0.0"
  }
}
