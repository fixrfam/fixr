{
  "name": "@fixr/schemas",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsc --watch",
    "build": "biome check && tsc",
    "lint": "biome check",
    "lint:write": "biome check --write"
  },
  "exports": {
    "./account": {
      "types": "./src/account.ts",
      "default": "./src/account.ts"
    },
    "./auth": {
      "types": "./src/auth.ts",
      "default": "./src/auth.ts"
    },
    "./roles": {
      "types": "./src/roles.ts",
      "default": "./src/roles.ts"
    },
    "./credentials": {
      "types": "./src/credentials.ts",
      "default": "./src/credentials.ts"
    },
    "./utils": {
      "types": "./src/utils.ts",
      "default": "./src/utils.ts"
    },
    "./companies": {
      "types": "./src/companies.ts",
      "default": "./src/companies.ts"
    },
    "./employees": {
      "types": "./src/employees.ts",
      "default": "./src/employees.ts"
    },
    "./common": {
      "types": "./src/common.ts",
      "default": "./src/common.ts"
    },
    "./clients": {
      "types": "./src/clients.ts",
      "default": "./src/clients.ts"
    },
    "./service-orders": {
      "types": "./src/service-orders.ts",
      "default": "./src/service-orders.ts"
    }
  },
  "devDependencies": {
    "@fixr/typescript-config": "workspace:*",
    "@types/eslint": "^8.56.5",
    "@types/node": "^20.11.24",
    "@biomejs/biome": "2.3.3",
    "typescript": "^5.3.3",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
